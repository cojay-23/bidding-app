# BidScope 环境变量配置
# 复制此文件为 .env 并填入真实值

# === 必需配置 ===

# Kimi/Moonshot API 密钥（用于高级分析）
MOONSHOT_API_KEY=sk-your-api-key-here

# 管理员用户名（默认 admin）
ADMIN_USERNAME=admin

# 管理员密码（生产环境务必设置强密码）
ADMIN_PASSWORD=your-strong-password-here

# === 可选配置 ===

# LLM 模型选择（默认 kimi-k2.6）
# LLM_MODEL=kimi-k2.6

# LLM API 基础 URL（默认 https://api.moonshot.cn/v1）
# LLM_BASE_URL=https://api.moonshot.cn/v1

# 会话密钥（留空则每次启动随机生成，重启后所有用户需重新登录）
# SESSION_SECRET=

# 会话有效期（秒，默认 86400 = 24小时）
# SESSION_TTL=86400

# 容器内非 root 用户的 UID/GID。部署到 Linux 服务器时，data 目录需要授权给同一组值。
# APP_UID=999
# APP_GID=999
